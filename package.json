{
  "name": "config-disassembler",
  "version": "2.1.0",
  "description": "Node.js bindings for the Rust config-disassembler crate.",
  "author": "Matt Carvin",
  "license": "MIT",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "napi": {
    "binaryName": "config-disassembler",
    "targets": [
      "x86_64-apple-darwin",
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-musl",
      "aarch64-unknown-linux-musl",
      "x86_64-pc-windows-msvc",
      "aarch64-pc-windows-msvc",
      "i686-pc-windows-msvc"
    ]
  },
  "scripts": {
    "artifacts": "napi artifacts",
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,ts}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*": "prettier --write \"**/*.{js,ts}\" --ignore-unknown"
  },
  "devDependencies": {
    "@commitlint/config-conventional": "^20.5.0",
    "@napi-rs/cli": "^3.6.2",
    "@types/node": "^25.5.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mcarvin8/config-disassembler-node.git"
  },
  "bugs": {
    "url": "https://github.com/mcarvin8/config-disassembler-node/issues"
  },
  "keywords": [
    "config",
    "disassemble",
    "disassembler",
    "reassemble",
    "xml",
    "json",
    "json5",
    "jsonc",
    "yaml",
    "toon",
    "toml",
    "ini",
    "salesforce",
    "rust",
    "napi-rs"
  ]
}

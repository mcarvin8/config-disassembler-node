{
  "compilerOptions": {
    "module": "ESNext",
    "target": "ES2015",
    "declaration": false,
    "sourceMap": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "removeComments": true,
    "types": ["node", "vitest/globals"],
    "allowJs": true,
    "noEmit": true
  },
  "include": ["index.d.ts", "test/**/*.ts"],
  "exclude": ["node_modules", "target"]
}
